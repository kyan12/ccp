{
  "mappings": [
    {
      "key": "my-app",
      "ownerRepo": "myorg/my-app",
      "gitUrl": "git@github.com:myorg/my-app.git",
      "localPath": "/home/user/repos/my-app",
      "aliases": ["my-app", "app"],
      "autoMerge": true,
      "mergeMethod": "squash",
      "agent": "claude-code",
      "agentFallback": "codex",
      "memoryFile": ".ccp/memory.md",
      "worktree": true,
      "parallelJobs": 2,
      "nightly": {
        "enabled": false,
        "branch": "main",
        "timeoutSec": 900
      },
      "validation": {
        "gate": false,
        "steps": [
          { "name": "install", "cmd": "npm ci --no-audit --no-fund", "timeoutSec": 300 },
          { "name": "typecheck", "cmd": "npm run typecheck", "timeoutSec": 300 },
          { "name": "lint", "cmd": "npm run lint", "timeoutSec": 180, "required": false },
          { "name": "test", "cmd": "npm test -- --run", "timeoutSec": 900 },
          { "name": "build", "cmd": "npm run build", "timeoutSec": 600 }
        ]
      }
    }
  ]
}
