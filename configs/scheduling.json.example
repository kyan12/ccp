{
  "enabled": true,
  "timezone": "America/New_York",
  "peakHours": {
    "comment": "Define windows where job dispatch is paused to conserve API quota",
    "windows": [
      {
        "days": ["mon", "tue", "wed", "thu", "fri"],
        "start": "08:00",
        "end": "14:00",
        "label": "anthropic-peak"
      }
    ]
  },
  "behavior": {
    "duringPeak": "queue",
    "allowRunningJobsToFinish": true,
    "allowUrgentOverride": true
  }
}
