# =============================================================================
# CodePlane Configuration
# Copy to .env and fill in your values
# =============================================================================

# --- Required ---

# Linear API key (https://linear.app/settings/api)
LINEAR_API_KEY=lin_api_xxxxx

# --- Coding Agent ---
# Global default for the coding agent used by the tmux worker.
# Precedence (highest wins):  JobPacket.agent  >  repos.json: mapping.agent  >  CCP_AGENT  >  'claude-code'
# Accepted values: 'claude-code' (alias: 'claude'), 'codex' (aliases: 'openai-codex', 'codex-cli').
# See docs/agents.md for per-repo fallback (`agentFallback`) and Linear `agent:<name>` label mapping.
# CCP_AGENT=

# Per-repo memory (Phase 5a) is configured via `memoryFile` in
# configs/repos.json — there is no env var equivalent. See docs/memory.md.

# Per-agent outage circuits are stored at configs/outage-<agent>.json. A one-time migration
# copies any legacy configs/outage.json into configs/outage-claude-code.json on first read.

# --- Discord Notifications (optional) ---
# Discord channel IDs for notifications (requires OpenClaw or Discord bot)
# CCP_DISCORD_RUNS_CHANNEL=       # START notifications only
# CCP_DISCORD_STATUS_CHANNEL=     # Full lifecycle: PR opened, checks, merged, remediation
# CCP_DISCORD_ERRORS_CHANNEL=     # Failures, blocked jobs, outages, rate limits

# --- PR Review ---
# Global auto-merge (can be overridden per-repo in repos.json)
# CCP_PR_AUTOMERGE=false
# CCP_PR_MERGE_METHOD=squash
# CCP_PR_REVIEW_ENABLED=true
# CCP_PR_REMEDIATE_ENABLED=true

# --- Vercel Integration (optional) ---
# VERCEL_TOKEN=
# VERCEL_WEBHOOK_SECRET=

# --- Sentry Integration (optional) ---
# SENTRY_AUTH_TOKEN=

# --- Intake Server ---
# CCP_INTAKE_PORT=4318

# --- Supervisor ---
# CCP_MAX_CONCURRENT=1
# CCP_SUPERVISOR_INTERVAL_MS=15000

# --- Post-worker Validation (see docs/validation.md) ---
# Globally disable per-repo static validation (install/typecheck/test/build)
# CCP_VALIDATION_ENABLED=true
# Phase 2b global gate override. When unset, each repo's validation.gate decides.
# Set to true/1/on/yes to gate every repo, or false/0/off/no to disable gating globally.
# CCP_VALIDATION_GATE=

# --- Git Identity (for automated commits) ---
# CCP_GIT_USER_NAME=CodePlane
# CCP_GIT_USER_EMAIL=codeplane@localhost
